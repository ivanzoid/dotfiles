# Default optinos:
# ghostty +show-config --default --docs` to view a list of
#
# Reload config: Cmd + Shift + ,
#
# Docs:
# https://ghostty.org/docs/config/reference
#

theme = light:Alabaster, dark:Afterglow
# background = #ffffff
# background = #000000
cursor-color = #666666
font-family = Fira Code Retina
font-size = 16.5
adjust-cell-height = +16%
adjust-cell-width = -4%
cursor-style = bar
cursor-style-blink = false
shell-integration-features = no-cursor, title
adjust-cursor-thickness = +200%
window-inherit-working-directory = false
working-directory = home

# custom-shader = ~/icloud/Resources/ghostty-shaders/cursor_blaze2.glsl

macos-icon = custom
macos-custom-icon = ~/icloud/Resources/ghostty-icons/ghostty-black.icns

# 100MB
scrollback-limit = 104857600

# mouse-scroll-multiplier = precision:0.5,discrete:3
scroll-to-bottom = keystroke

# Shift+drag does a local Ghostty selection (mouse-shift-capture defaults to
# false, so Shift overrides tmux's mouse grab) and this copies it straight to
# the macOS clipboard. Needed because mosh drops tmux's OSC 52 clipboard writes,
# so mouse-select copy that works over ssh is dead over mosh.
copy-on-select = clipboard

keybind = cmd+shift+a=text:mosh ivan@ai.local\n
keybind = cmd+shift+r=reset

# Cmd+N / Cmd+T are intercepted by Hammerspoon (~/.hammerspoon/init.lua) so a new
# window/tab re-connects (mosh) into the current tab's remote dir. Hammerspoon
# triggers Ghostty's *native* new tab/window via these dedicated binds, avoiding
# recursion with the Cmd+N / Cmd+T it captures.
keybind = cmd+ctrl+t=new_tab
keybind = cmd+ctrl+n=new_window

# --- main view defaults ---

# Custom date format -> "26-07-06 15:04"
set main-view-date        = custom
set main-view-date-format = "%y-%m-%d %H:%M"

# Short author -> initials (e.g. "IZ")
set main-view-author      = abbreviated

# Show the commit hash / ID column (":toggle id")
set main-view-id          = yes

# Revision graph on by default, drawn with box-drawing chars ("line-graphics")
set main-view-commit-title-graph = yes
set line-graphics = utf-8

# file-name is not a main-view column; it lives in these views (shown on
# "auto" by default). Force it always visible:
set tree-view-file-name  = always
set blame-view-file-name = always

# --- diff colors ---
# Pale pastel backgrounds like Claude Code's diff, with dark text.
# tig 2.6.1 has no truecolor, so use fixed xterm-256 cube entries (16-255),
# which themes don't remap -> stays the same regardless of terminal theme:
#   194 = #d7ffd7 (~Claude #e0fed9 added)   224 = #ffd7d7 (~Claude #f9d8d8 removed)
#   236 = #303030 (Claude's dark diff text)
# The *2 variants are the second column shown in merge/combined diffs.
color diff-add   color236 color194
color diff-add2  color236 color194
color diff-del   color236 color224
color diff-del2  color236 color224
